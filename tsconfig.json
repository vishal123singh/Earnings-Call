{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/app/*"],
      "@components/*": ["./src/app/components/*"],
      "@utils/*": ["./src/app/utils/*"],
      "@hooks/*": ["./src/app/hooks/*"],
      "@styles/*": ["./src/app/styles/*"],
      "@assets/*": ["./src/app/assets/*"],
      "@lib/*": ["./src/app/lib/*"],
      "@context/*": ["./src/app/context/*"],
      "@services/*": ["./src/app/services/*"],
      "@types/*": ["./src/app/types/*"],
      "@public/*": ["./public/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/app/components/charts/index.js",
    "src/app/about/page.jsx",
    "src/app/components/ui/market-metrics.tsx",
    "src/app/insights/page.jsx",
    "src/app/competitive-insights/DynamicChartCreator.jsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
